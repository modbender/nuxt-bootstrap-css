{
  "name": "nuxt-bootstrap-css",
  "version": "1.2.0",
  "description": "Quite the hassle to setup bootstrap, so here is the shortcut",
  "repository": "modbender/nuxt-bootstrap-css",
  "homepage": "https://modbender.in/nuxt-bootstrap-css/",
  "keywords": [
    "vue",
    "vue.js",
    "vue3",
    "vue 3",
    "nuxt",
    "nuxt3",
    "nuxt 3",
    "nuxt4",
    "nuxt 4",
    "bootstrap nuxt module",
    "bootstrap nuxt3",
    "css",
    "sass",
    "mobile-first",
    "responsive",
    "front-end",
    "framework",
    "web"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^3.13.0 || ^4.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.0.0",
    "@nuxt/test-utils": "^4.0.3",
    "@types/bootstrap": "^5.2.11",
    "@types/node": "^22.10.0",
    "changelogen": "^0.6.2",
    "eslint": "^9.18.0",
    "nuxt": "^4.0.0",
    "typescript": "~5.7.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@10.26.0"
}
